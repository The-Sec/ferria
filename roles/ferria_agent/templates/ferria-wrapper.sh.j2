#!/usr/bin/env bash
# Managed by Ferria — manual changes will be overwritten on next convergence run.
# Generated by: roles/ferria_agent/templates/ferria-wrapper.sh.j2
#
# ferria-wrapper.sh — executed by ferria-agent.service on each timer tick.
# Loads configuration and verifies commits,
# then runs ansible-pull to converge the machine toward desired state.

set -euo pipefail

log() { echo "[ferria] $(date -Iseconds) $*"; }
log_error() { echo "[ferria] $(date -Iseconds) ERROR: $*" >&2; }

log "Ferria convergence run starting..."

# --- Load configuration ---
CONF_FILE="/etc/ferria/agent.conf"
if [[ ! -f "$CONF_FILE" ]]; then
    log_error "Configuration file not found: ${CONF_FILE}"
    exit 1
fi
# shellcheck source=/dev/null
source "$CONF_FILE"
FERRIA_SSH_STRICT_HOST_KEY_CHECKING="${FERRIA_SSH_STRICT_HOST_KEY_CHECKING:-accept-new}"

# --- Activate Python venv ---
if [[ ! -f "${FERRIA_VENV_PATH}/bin/activate" ]]; then
    log_error "Python venv not found at ${FERRIA_VENV_PATH}. Re-run bootstrap.sh."
    exit 1
fi
# shellcheck source=/dev/null
source "${FERRIA_VENV_PATH}/bin/activate"

# --- Commit verification ---
if [[ "${FERRIA_COMMIT_VERIFY}" == "true" ]]; then
    log "Verifying latest commit signature..."
    GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=${FERRIA_SSH_STRICT_HOST_KEY_CHECKING}" \
        git -C "${FERRIA_REPO_DEST}" fetch origin "${FERRIA_REPO_BRANCH}"
    if ! git -C "${FERRIA_REPO_DEST}" verify-commit FETCH_HEAD; then
        log_error "Commit verification FAILED. Refusing to apply unverified state."
        exit 1
    fi
    log "Commit signature verified."
fi

# --- Set SOPS age key if available ---
if [[ -f "${FERRIA_AGE_KEY_PATH}" ]]; then
    export SOPS_AGE_KEY_FILE="${FERRIA_AGE_KEY_PATH}"
    log "SOPS age key loaded from ${FERRIA_AGE_KEY_PATH}"
fi

# --- Log current commit ---
CURRENT_COMMIT=$(git -C "${FERRIA_REPO_DEST}" rev-parse HEAD 2>/dev/null || echo "unknown")
log "Current commit: ${CURRENT_COMMIT}"

# --- Build ansible-pull arguments ---
PULL_ARGS=(
    -U "${FERRIA_REPO_URL}"
    -C "${FERRIA_REPO_BRANCH}"
    -d "${FERRIA_REPO_DEST}"
    -i inventory/hosts.yml
    local.yml
)

# -o: only run playbook if the repository has changed (skip if no new commits).
[[ "${FERRIA_ONLY_IF_CHANGED}" == "true" ]] && PULL_ARGS+=(-o)

# --clean: discard any local modifications to the working copy before pull.
[[ "${FERRIA_CLEAN_CHECKOUT}" == "true" ]] && PULL_ARGS+=(--clean)

log "Running: ansible-pull ${PULL_ARGS[*]}"

# --- Execute ansible-pull ---
START=$(date +%s)
set +e
GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=${FERRIA_SSH_STRICT_HOST_KEY_CHECKING}" \
    ansible-pull "${PULL_ARGS[@]}"
RC=$?
set -e
END=$(date +%s)

APPLIED_COMMIT=$(git -C "${FERRIA_REPO_DEST}" rev-parse HEAD 2>/dev/null || echo "unknown")
log "Applied commit: ${APPLIED_COMMIT}"
log "Convergence run complete in $(( END - START ))s (exit code: ${RC})"

exit $RC
